# ═══════════════════════════════════════════════════════════════
# Klinkragency Dashboard — Environment Configuration
# Copy this file to .env.local and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ─── Database (matches docker-compose defaults) ──────────────
POSTGRES_USER=esnackcrm
POSTGRES_PASSWORD=esnackcrm_dev
POSTGRES_DB=esnackcrm_db
DATABASE_URL=postgres://esnackcrm:esnackcrm_dev@localhost:5433/esnackcrm_db

# ─── Better Auth ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=CHANGE_ME_32_BYTES_HEX
BETTER_AUTH_URL=http://localhost:3000

# ─── Email (Resend) ──────────────────────────────────────────
# Leave RESEND_API_KEY empty to log magic links to the console instead
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@klinkragency.fr

# ─── First-boot admin seed ───────────────────────────────────
# Your email — pre-seeded at first startup if the user table is empty.
INITIAL_DASHBOARD_ADMIN_EMAIL=you@klinkragency.fr
INITIAL_DASHBOARD_ADMIN_NAME=Admin
